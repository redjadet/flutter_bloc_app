# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/lcov.info

# Integration test runner output (per-run summaries)
/artifacts/
artifacts/integration/
# Perf trace artifacts (traceAction report data)
artifacts/perf/

# Golden test failure artifacts
test/failures/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Platform build outputs – all files and subfolders recursively (do not commit)
**/build/**

# Gradle cache (e.g. third_party plugin builds)
**/.gradle/

# Local secrets
assets/config/secrets.json
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist
firebase.json
# Placeholder `lib/firebase_options.dart` is committed so the app runs
# without Firebase. `flutterfire configure` overwrites it; do not commit
# real project config.
third_party/pub/firebase_remote_config/example/lib/firebase_options.dart
INTERVIEW_QA.md

.config/
# Local agent overlays (skills, symlinks, host-only policy); not part of the app build
.agents/
# Local-only host adapter templates; not required for fresh clones
tool/agent_host_templates/
coverage/lcov.base.info

# Agent scorecard one-off exports (keep the rolling log tracked)
analysis/agent_scorecard/scorecard-events-*.jsonl
AGENTS.md
docs/gstack_integration.md
tmp_test_write.md
.env.android.release
fastlane/keys/*.json
fastlane/report.xml

# Local direnv config (do not commit)
.envrc

