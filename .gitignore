# Tracked templates:
# - assets/config/secrets.sample.json
# - android/app/google-services.json.sample
# - ios/Runner/GoogleService-Info.plist.sample
# - macos/Runner/GoogleService-Info.plist.sample
# - firebase.json.example
# - docs/envrc.example
# Placeholder `lib/firebase_options.dart` is committed so the app runs
# without Firebase. `flutterfire configure` overwrites it; do not commit
# real project config.
third_party/pub/firebase_remote_config/example/lib/firebase_options.dart
