# LEGACY STUB — canonical Android lanes live in ../../fastlane/Fastfile.
# Run from repo root: ./tool/release_android_play.sh upload_internal
# Or both stores: ./tool/release_both_stores.sh deploy

fastlane_version '2.221.0'

default_platform(:android)

def bump_pubspec_build_number
  pubspec_path = File.expand_path('../../pubspec.yaml', __dir__)
  UI.user_error!("pubspec.yaml not found at #{pubspec_path}") unless File.exist?(pubspec_path)

  content = File.read(pubspec_path)
  match = content.match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
  UI.user_error!('Could not locate version line in pubspec.yaml') unless match

  semantic_version = match[1]
  build_number = match[2].to_i + 1
  updated_line = "version: #{semantic_version}+#{build_number}"

  File.write(pubspec_path, content.sub(match[0], updated_line))
  UI.message("Updated pubspec.yaml build number to #{build_number}")

  { version: semantic_version, build_number: build_number }
end

platform :android do
  desc 'Build a release appbundle via Flutter'
  lane :build do |options|
    flavor = options[:flavor] || ENV['ANDROID_BUILD_FLAVOR']
    bundle_dir = 'build/app/outputs/bundle'

    sh('flutter', 'pub', 'get')
    sh('dart', 'run', 'tool/prepare_release.dart')

    args = %w[flutter build appbundle --release]
    args << '--flavor' << flavor if flavor
    sh(*args)

    sh('ls', '-R', bundle_dir) if ENV['FL_FASTLANE_DEBUG'] == 'true'
  end

  desc 'Build and upload a Flutter appbundle to Google Play'
  lane :deploy do |options|
    track = options[:track] || ENV['ANDROID_PLAY_TRACK'] || 'internal'
    flavor = options[:flavor] || ENV['ANDROID_BUILD_FLAVOR']

    build_info = bump_pubspec_build_number
    UI.message(
      "Preparing deploy for #{build_info[:version]}+#{build_info[:build_number]}",
    )

    invoke(:build, flavor: flavor)

    aab = if flavor
            "build/app/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab"
          else
            'build/app/outputs/bundle/release/app-release.aab'
          end

    UI.user_error!("Could not find AAB at #{aab}") unless File.exist?(aab)

    upload_to_play_store(
      track: track,
      aab: aab,
      skip_upload_apk: true,
      skip_upload_images: true,
      skip_upload_metadata: ENV['ANDROID_UPLOAD_METADATA'] != 'true',
      skip_upload_screenshots: true,
    )
  end
  desc 'Build APK and upload to Firebase App Distribution'
  lane :firebase_distribute do |options|
    release_notes = options[:release_notes] || ENV['FIREBASE_RELEASE_NOTES'] || "Pre-release Android - " + Time.now.strftime('%Y-%m-%d %H:%M')
    groups = options[:groups] || ENV['FIREBASE_GROUPS']
    testers = options[:testers] || ENV['FIREBASE_TESTERS']
    skip_build = options[:skip_build] || (ENV['FIREBASE_SKIP_BUILD'] == 'true')
    use_apk = options.fetch(:apk, ENV['FIREBASE_USE_APK'] != 'false')

    project_root = File.expand_path('../..', __dir__)
    Dir.chdir(project_root) do
      unless skip_build
        sh('flutter', 'pub', 'get')
        sh('dart', 'run', 'tool/prepare_release.dart')
        if use_apk
          sh('flutter', 'build', 'apk', '--release')
        else
          invoke(:build)
        end
      end

      binary = if use_apk
                 apk = File.join(project_root, 'build/app/outputs/flutter-apk/app-release.apk')
                 UI.user_error!("No APK found at \#{apk}") unless File.exist?(apk)
                 apk
               else
                 aab = File.join(project_root, 'build/app/outputs/bundle/release/app-release.aab')
                 UI.user_error!("No AAB found at \#{aab}") unless File.exist?(aab)
                 aab
               end

      firebase_args = ['firebase', 'appdistribution:distribute', binary,
        '--app', ENV.fetch('FIREBASE_ANDROID_APP_ID', '1:473097776453:android:80db6a1c2b04bfc0bd222c'),
        '--release-notes', release_notes]
      firebase_args.concat(['--groups', groups]) if groups && !groups.empty?
      firebase_args.concat(['--testers', testers]) if testers && !testers.empty?

      sh(*firebase_args)
    end
    UI.success('Firebase App Distribution upload complete. Check Firebase Console.')
  end

end
