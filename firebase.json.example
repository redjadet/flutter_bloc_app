{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "your-project-id",
          "appId": "1:000000000000:android:placeholder",
          "fileOutput": "apps/mobile/android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "your-project-id",
          "appId": "1:000000000000:ios:placeholder",
          "uploadDebugSymbols": true,
          "fileOutput": "apps/mobile/ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "your-project-id",
          "appId": "1:000000000000:ios:placeholder",
          "uploadDebugSymbols": true,
          "fileOutput": "apps/mobile/macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "apps/mobile/lib/firebase_options.dart": {
          "projectId": "your-project-id",
          "configurations": {
            "android": "1:000000000000:android:placeholder",
            "ios": "1:000000000000:ios:placeholder",
            "macos": "1:000000000000:ios:placeholder"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
