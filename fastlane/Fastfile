fastlane_version '2.234.0'

# Canonical Fastfile for this repo (invoked via ./tool/fastlane.sh from project root).
# Platform-specific copies under ios/fastlane and android/fastlane are legacy stubs.
default_platform(:android)

def project_root
  File.expand_path('..', __dir__)
end

def tool_path(script_name)
  File.expand_path(File.join(project_root, 'tool', script_name))
end

def metadata_path
  File.expand_path(File.join(__dir__, 'metadata', 'android'))
end

def release_notes_for(locale, build_number)
  explicit_path = File.join(metadata_path, locale, 'changelogs', "#{build_number}.txt")
  default_path = File.join(metadata_path, locale, 'changelogs', 'default.txt')

  return File.read(explicit_path).strip if File.exist?(explicit_path)
  return File.read(default_path).strip if File.exist?(default_path)

  "Release build #{build_number}"
end

def bump_pubspec_build_number!
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  UI.user_error!("pubspec.yaml not found at #{pubspec_path}") unless File.exist?(pubspec_path)

  content = File.read(pubspec_path)
  match = content.match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
  UI.user_error!('Could not locate version line in pubspec.yaml') unless match

  semantic_version = match[1]
  build_number = match[2].to_i + 1
  updated_line = "version: #{semantic_version}+#{build_number}"

  File.write(pubspec_path, content.sub(match[0], updated_line))
  UI.message("Updated pubspec.yaml build number to #{build_number}")

  { version: semantic_version, build_number: build_number }
end

def current_pubspec_version
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  content = File.read(pubspec_path)
  match = content.match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)/)
  UI.user_error!('Could not locate version line in pubspec.yaml') unless match
  { version: match[1], build_number: match[2].to_i }
end

def ensure_release_inputs!
  UI.user_error!(
    'Set ANDROID_PACKAGE_NAME before Play upload.',
  ) if ENV['ANDROID_PACKAGE_NAME'].to_s.strip.empty?

  UI.user_error!(
    'Set ANDROID_JSON_KEY to a local service account JSON path for Play upload.',
  ) if ENV['ANDROID_JSON_KEY'].to_s.strip.empty?

  UI.user_error!(
    "Service account key not found at #{ENV['ANDROID_JSON_KEY']}",
  ) unless File.exist?(ENV['ANDROID_JSON_KEY'])

  UI.user_error!(
    'Set SUPABASE_URL before release builds.',
  ) if ENV['SUPABASE_URL'].to_s.strip.empty?

  UI.user_error!(
    'Set SUPABASE_ANON_KEY before release builds.',
  ) if ENV['SUPABASE_ANON_KEY'].to_s.strip.empty?

  UI.user_error!(
    'Set HUGGINGFACE_API_KEY before release builds.',
  ) if ENV['HUGGINGFACE_API_KEY'].to_s.strip.empty?

  begin
    require 'json'
    data = JSON.parse(File.read(ENV['ANDROID_JSON_KEY']))
    required_keys = %w[client_email private_key project_id token_uri]
    missing = required_keys.reject { |k| data.key?(k) && !data[k].to_s.strip.empty? }
    UI.user_error!(
      "ANDROID_JSON_KEY is missing required fields: #{missing.join(', ')}",
    ) unless missing.empty?
  rescue JSON::ParserError => e
    UI.user_error!(
      "ANDROID_JSON_KEY is not valid JSON: #{e.message}",
    )
  end
end

def flutter_dart_defines
  defines = []
  Dir.chdir(project_root) do
    output = sh(tool_path('flutter_dart_defines_from_env.sh'), log: false).to_s
    defines = output.split(/\s+/).map(&:strip).reject(&:empty?)
  end
  defines
end

def aab_path_for(flavor)
  cleaned_flavor = flavor.to_s.strip
  if !cleaned_flavor.empty?
    "build/app/outputs/bundle/#{cleaned_flavor}Release/app-#{cleaned_flavor}-release.aab"
  else
    'build/app/outputs/bundle/release/app-release.aab'
  end
end

def resolve_aab_path(flavor)
  relative = aab_path_for(flavor)
  absolute = File.expand_path(relative, project_root)
  return absolute if File.exist?(absolute)

  fallback = Dir.glob(File.join(project_root, '**', 'app-*-release.aab'))
                .find { |p| p.include?('/outputs/bundle/') }
  return fallback if fallback && File.exist?(fallback)

  nil
end

def release_notes_from_git(commits_count: 5)
  return nil unless system('git', 'rev-parse', '--git-dir', out: File::NULL, err: File::NULL)

  changelog_from_git_commits(
    commits_count: commits_count,
    pretty: '- %s',
    merge_commit_filtering: 'exclude_merges',
  )
rescue StandardError => e
  UI.important("Could not build git release notes: #{e.message}")
  nil
end

def release_notes_for_ios(locale: 'en-US')
  explicit = ENV['IOS_RELEASE_NOTES'].to_s.strip
  return explicit unless explicit.empty?

  git_notes = release_notes_from_git
  return git_notes if git_notes && !git_notes.strip.empty?

  build_number = current_pubspec_version[:build_number]
  release_notes_for(locale, build_number)
end

def sync_ios_signing_with_match!(options = {})
  match_git = ENV['MATCH_GIT_URL'].to_s.strip
  return if match_git.empty?

  match_type = (options[:type] || ENV['MATCH_TYPE'] || 'appstore').to_s
  readonly = options.key?(:readonly) ? options[:readonly] : ENV['MATCH_READONLY'] != 'false'

  match_params = {
    type: match_type,
    readonly: readonly,
    git_url: match_git,
    app_identifier: ENV['FASTLANE_APP_IDENTIFIER'],
    username: ENV['FASTLANE_APPLE_ID'],
    team_id: ENV['FASTLANE_TEAM_ID'],
  }.compact

  match(match_params)
end

def build_flutter(platform, options = {})
  clean = options.key?(:clean) ? options[:clean] : ENV['FLUTTER_CLEAN_BEFORE_BUILD'] == 'true'
  bump_build = options.key?(:bump_build) ? options[:bump_build] : false
  flavor = (options[:flavor] || ENV['ANDROID_BUILD_FLAVOR'] || ENV['IOS_BUILD_FLAVOR']).to_s.strip
  flavor = nil if flavor.empty?

  build_info = bump_build ? bump_pubspec_build_number! : current_pubspec_version
  UI.message("Flutter build #{build_info[:version]}+#{build_info[:build_number]} (#{platform})")

  Dir.chdir(project_root) do
    sh('flutter', 'clean') if clean
    sh('flutter', 'pub', 'get')
    sh('dart', 'run', 'tool/prepare_release.dart') unless options[:skip_prepare_release]

    case platform
    when :ios
      entrypoint = options[:entrypoint] || ENV['IOS_ENTRYPOINT'] || 'lib/main_prod.dart'
      build_mode = options[:build_mode] || ENV['IOS_BUILD_MODE'] || 'release'
      args = ['flutter', 'build', 'ipa', "--#{build_mode}", "--target=#{entrypoint}"]
      args.concat(['--flavor', flavor]) if flavor
      defines = flutter_dart_defines
      args.concat(defines)
      sh(*args, log: false)
    when :android
      args = %w[flutter build appbundle --release]
      args << '--no-tree-shake-icons' if ENV['ANDROID_NO_TREE_SHAKE_ICONS'] != 'false'
      args.concat(['--flavor', flavor]) if flavor
      defines = flutter_dart_defines
      args.concat(defines)
      sh(*args, log: false)
      sh('ls', '-R', 'build/app/outputs/bundle') if ENV['FL_FASTLANE_DEBUG'] == 'true'
    else
      UI.user_error!("Unsupported platform for build_flutter: #{platform}")
    end
  end

  build_info
end

def invoke_platform_lane(platform_name, lane_name, options = {})
  args = [lane_name]
  options.each do |key, value|
    next if value.nil?

    args << "#{key}:#{value}"
  end
  sh('bundle', 'exec', 'fastlane', platform_name.to_s, *args)
end

platform :android do
  desc 'Run preflight checks for Android Play deploy lanes'
  lane :play_preflight do
    ensure_release_inputs!
    UI.message("Using package #{ENV['ANDROID_PACKAGE_NAME']}")
    UI.message("Using key file #{ENV['ANDROID_JSON_KEY']}")
  end

  desc 'Alias for play_preflight (backward compatibility)'
  lane :preflight do
    play_preflight
  end

  desc 'Build a release appbundle via Flutter'
  lane :play_build_release do |options|
    bump_build = options.key?(:bump_build) ? options[:bump_build] : true
    flavor = (options[:flavor] || ENV['ANDROID_BUILD_FLAVOR']).to_s.strip
    flavor = nil if flavor.empty?

    build_flutter(
      :android,
      bump_build: bump_build,
      flavor: flavor,
      clean: ENV['FLUTTER_CLEAN_BEFORE_BUILD'] == 'true',
    )
  end

  desc 'Alias for play_build_release (backward compatibility)'
  lane :build_release do |options|
    play_build_release(options)
  end

  desc 'Sync listing metadata/screenshots from fastlane/metadata/android to Play'
  lane :play_metadata_sync do |options|
    track = options[:track] || ENV['ANDROID_PLAY_TRACK'] || 'internal'
    locale = options[:locale] || ENV['ANDROID_METADATA_LOCALE'] || 'en-US'

    play_preflight
    UI.user_error!(
      "Metadata directory missing at #{metadata_path}",
    ) unless Dir.exist?(metadata_path)

    upload_to_play_store(
      track: track,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_changelogs: false,
      metadata_path: metadata_path,
      skip_upload_images: false,
      skip_upload_metadata: false,
      skip_upload_screenshots: false,
      json_key: ENV['ANDROID_JSON_KEY'],
      package_name: ENV['ANDROID_PACKAGE_NAME'],
    )
  end

  desc 'Alias for play_metadata_sync (backward compatibility)'
  lane :metadata_sync do |options|
    play_metadata_sync(options)
  end

  desc 'Build + upload AAB to Internal testing'
  lane :play_upload_internal do |options|
    play_upload_track(options.merge(track: 'internal'))
  end

  desc 'Alias for play_upload_internal (backward compatibility)'
  lane :upload_internal do |options|
    play_upload_internal(options)
  end

  desc 'Build + upload AAB to requested Play track'
  lane :play_upload_track do |options|
    track = options[:track] || ENV['ANDROID_PLAY_TRACK'] || 'internal'
    flavor = (options[:flavor] || ENV['ANDROID_BUILD_FLAVOR']).to_s.strip
    flavor = nil if flavor.empty?
    locale = options[:locale] || ENV['ANDROID_METADATA_LOCALE'] || 'en-US'
    bump_build = options.key?(:bump_build) ? options[:bump_build] : true

    play_preflight
    build_info = play_build_release(flavor: flavor, bump_build: bump_build)
    UI.message("Preparing Play upload for #{build_info[:version]}+#{build_info[:build_number]}")

    aab = resolve_aab_path(flavor)
    UI.user_error!(
      "Could not find AAB. Expected #{aab_path_for(flavor)} (from project root)",
    ) unless aab

    upload_params = {
      track: track,
      aab: aab,
      release_status: options[:release_status] || ENV['ANDROID_RELEASE_STATUS'] || 'draft',
      skip_upload_changelogs: false,
      skip_upload_apk: true,
      skip_upload_images: ENV['ANDROID_UPLOAD_IMAGES'] != 'true',
      skip_upload_metadata: ENV['ANDROID_UPLOAD_METADATA'] != 'true',
      skip_upload_screenshots: ENV['ANDROID_UPLOAD_SCREENSHOTS'] != 'true',
      metadata_path: metadata_path,
      json_key: ENV['ANDROID_JSON_KEY'],
      package_name: ENV['ANDROID_PACKAGE_NAME'],
      version_name: build_info[:version],
      version_code: build_info[:build_number],
    }
    upload_to_play_store(upload_params)
  end

  desc 'Alias for play_upload_track (backward compatibility)'
  lane :upload_track do |options|
    play_upload_track(options)
  end

  desc 'Promote release from one Play track to another'
  lane :play_promote_track do |options|
    from_track = options[:from] || ENV['ANDROID_PROMOTE_FROM'] || 'internal'
    to_track = options[:to] || ENV['ANDROID_PROMOTE_TO'] || 'production'
    release_status = options[:release_status] || ENV['ANDROID_RELEASE_STATUS'] || 'draft'
    rollout = options[:rollout] || ENV['ANDROID_ROLLOUT_FRACTION']

    play_preflight

    promote_track(
      track: from_track,
      to_track: to_track,
      release_status: release_status,
      rollout: rollout,
      json_key: ENV['ANDROID_JSON_KEY'],
      package_name: ENV['ANDROID_PACKAGE_NAME'],
    )
  end

  desc 'Alias for play_promote_track (backward compatibility)'
  lane :promote_track do |options|
    play_promote_track(options)
  end
end

platform :ios do
  desc 'Run preflight checks for iOS distribution lanes'
  lane :preflight do
    UI.user_error!(
      'Set FASTLANE_APP_IDENTIFIER (or configure it in an iOS Appfile) before iOS lanes.',
    ) if ENV['FASTLANE_APP_IDENTIFIER'].to_s.strip.empty?

    UI.user_error!(
      'Set FASTLANE_APPLE_ID before TestFlight/App Store lanes.',
    ) if ENV['FASTLANE_APPLE_ID'].to_s.strip.empty? && (ENV['FL_IOS_REQUIRE_APPLE_ID'] == 'true')
  end

  def resolve_ipa_path
    candidates = Dir.glob(File.join(project_root, 'build', 'ios', '**', '*.ipa'))
    candidates.first
  end

  desc 'Build and export an Ad Hoc IPA (no upload)'
  lane :adhoc do |options|
    skip_build = options[:skip_build] || ENV['IOS_SKIP_BUILD'] == 'true'
    entrypoint = options[:entrypoint] || ENV['IOS_ENTRYPOINT'] || 'lib/main_prod.dart'
    flavor = options[:flavor] || ENV['IOS_BUILD_FLAVOR']
    build_mode = options[:build_mode] || ENV['IOS_BUILD_MODE'] || 'release'

    preflight

    Dir.chdir(project_root) do
      sh(tool_path('ios_entitlements.sh'), 'distribution') if options.fetch(:distribution_entitlements, true)
      sh('dart', 'run', 'tool/prepare_release.dart') unless options[:skip_prepare_release]

      unless skip_build
        env = {
          'ENTRYPOINT' => entrypoint,
          'FLAVOR' => flavor.to_s,
          'BUILD_MODE' => build_mode.to_s,
        }.compact
        sh(env, tool_path('build_ios_with_direnv.sh'))
      end
    end

    ipa = options[:ipa] || resolve_ipa_path
    UI.user_error!('No IPA found under build/ios/**/*.ipa') unless ipa && File.exist?(ipa)
    UI.message("Built IPA at #{ipa}")
    ipa
  end

  desc 'Build + upload to TestFlight (App Store Connect)'
  lane :upload_testflight do |options|
    ENV['FL_IOS_REQUIRE_APPLE_ID'] = 'true'
    preflight
    sync_ios_signing_with_match!(options)

    ipa = adhoc(options)
    changelog = release_notes_for_ios
    upload_params = {
      ipa: ipa,
      username: ENV['FASTLANE_APPLE_ID'],
      team_id: ENV['FASTLANE_TEAM_ID'],
      skip_waiting_for_build_processing: options.fetch(:skip_waiting_for_build_processing, true),
      distribute_external: options.fetch(:distribute_external, false),
      submit_beta_review: options.fetch(:submit_beta_review, false),
    }
    upload_params[:changelog] = changelog if changelog && !changelog.strip.empty?
    upload_to_testflight(upload_params)
  end

  desc 'Build + upload to App Store Connect (metadata optional; does not auto-submit for review)'
  lane :upload_appstore do |options|
    ENV['FL_IOS_REQUIRE_APPLE_ID'] = 'true'
    preflight
    sync_ios_signing_with_match!(options)

    ipa = adhoc(options)
    locale = options[:locale] || ENV['IOS_METADATA_LOCALE'] || 'en-US'
    changelog = release_notes_for_ios(locale: locale)
    release_notes = {}
    release_notes[locale] = changelog if changelog && !changelog.strip.empty?

    upload_to_app_store(
      ipa: ipa,
      username: ENV['FASTLANE_APPLE_ID'],
      team_id: ENV['FASTLANE_TEAM_ID'],
      skip_screenshots: options.fetch(:skip_screenshots, true),
      skip_metadata: options.fetch(:skip_metadata, ENV['IOS_SKIP_METADATA'] == 'true'),
      skip_binary_upload: false,
      submit_for_review: options.fetch(:submit_for_review, false),
      automatic_release: options.fetch(:automatic_release, false),
      release_notes: release_notes.empty? ? nil : release_notes,
    )
  end

  desc 'Alias for upload_testflight (backward compatibility)'
  lane :deploy do |options|
    upload_testflight(options)
  end

  desc 'Upload an iOS IPA to Firebase App Distribution'
  lane :firebase_distribute do |options|
    release_notes = options[:release_notes] || ENV['FIREBASE_RELEASE_NOTES'] || "Release uploaded #{Time.now.strftime('%Y-%m-%d')}"
    groups = options[:groups] || ENV['FIREBASE_GROUPS'].to_s
    testers = options[:testers] || ENV['FIREBASE_TESTERS'].to_s
    skip_build = options[:skip_build] || ENV['FIREBASE_SKIP_BUILD'] == 'true'

    ipa = skip_build ? (options[:ipa] || resolve_ipa_path) : adhoc(options)
    UI.user_error!('No IPA found under build/ios/**/*.ipa') unless ipa && File.exist?(ipa)

    recipient = groups.to_s.strip.empty? ? testers.to_s.strip : groups.to_s.strip
    UI.user_error!(
      'Set FIREBASE_GROUPS or FIREBASE_TESTERS (or pass groups:/testers:) for Firebase distribution.',
    ) if recipient.empty?

    Dir.chdir(project_root) do
      sh(tool_path('upload_ios_to_firebase_app_distribution.sh'), ipa, release_notes, recipient)
    end
  end
end

desc 'Preflight both store deploy lanes (iOS + Android)'
lane :deploy_all_preflight do
  invoke_platform_lane(:ios, 'preflight')
  invoke_platform_lane(:android, 'play_preflight')
  UI.success('Both store preflight checks passed.')
end

desc 'Deploy iOS (TestFlight) then Android (Play internal track) with one command'
lane :deploy_all do |options|
  ios_lane = options[:ios_lane] || ENV['IOS_DEPLOY_LANE'] || 'upload_testflight'
  android_lane = options[:android_lane] || ENV['ANDROID_DEPLOY_LANE'] || 'play_upload_internal'
  lane_options = options.dup
  bump_once = lane_options.key?(:bump_build) ? lane_options[:bump_build] : true

  if bump_once
    bump_pubspec_build_number!
    lane_options[:bump_build] = false
  end

  UI.header("iOS lane: #{ios_lane}")
  invoke_platform_lane(:ios, ios_lane, lane_options)

  UI.header("Android lane: #{android_lane}")
  invoke_platform_lane(:android, android_lane, lane_options)

  UI.success('deploy_all finished (iOS + Android). Review drafts in App Store Connect and Play Console.')
end
