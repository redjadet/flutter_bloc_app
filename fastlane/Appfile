json_key_file(ENV['ANDROID_JSON_KEY'])
package_name(ENV['ANDROID_PACKAGE_NAME'])

# iOS lanes read these from env to avoid hardcoding repo-local values.
app_identifier(ENV['FASTLANE_APP_IDENTIFIER']) if ENV['FASTLANE_APP_IDENTIFIER'].to_s.strip != ''
apple_id(ENV['FASTLANE_APPLE_ID']) if ENV['FASTLANE_APPLE_ID'].to_s.strip != ''
team_id(ENV['FASTLANE_TEAM_ID']) if ENV['FASTLANE_TEAM_ID'].to_s.strip != ''
