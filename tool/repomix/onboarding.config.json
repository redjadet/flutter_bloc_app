{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".repomix/onboarding-pack.md",
    "style": "markdown",
    "directoryStructure": true,
    "files": true,
    "fileSummary": true,
    "instructionFilePath": "llms.txt",
    "removeComments": false,
    "removeEmptyLines": false
  },
  "include": [
    "AGENTS.md",
    "CODEMAP.md",
    "llms.txt",
    "docs/ai/repo_map.md",
    "docs/feature_overview.md",
    "melos.yaml",
    "pubspec.yaml",
    "apps/mobile/pubspec.yaml",
    "apps/mobile/lib/app/router/app_routes.dart",
    "apps/mobile/lib/app/router/route_groups.dart",
    "apps/mobile/lib/app/composition/injector.dart",
    "apps/mobile/lib/app/composition/injector_registrations.dart",
    "apps/mobile/lib/app/composition/groups/*.dart",
    "packages/*/lib/*.dart",
    "packages/*/pubspec.yaml"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/*.freezed.dart",
      "**/*.g.dart",
      "**/*.gr.dart",
      "**/.dart_tool/**",
      "**/build/**",
      "ai/reports/FINAL_OPTIMIZATION_REPORT.md",
      ".repomix/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
