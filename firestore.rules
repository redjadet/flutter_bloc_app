rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WalletConnect Auth: one document per user at users/{userId} (linkage + profile)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Chart trending cache: written by server, readable by signed-in users.
    match /chart_trending/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
