rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function staffDemoProfile() {
      return get(/databases/$(database)/documents/staffDemoProfiles/$(request.auth.uid));
    }

    function staffDemoRole() {
      return staffDemoProfile().data.role;
    }

    function isStaffDemoManagerOrAccountant() {
      return isSignedIn() &&
        (staffDemoRole() == "manager" || staffDemoRole() == "accountant");
    }

    // Staff app demo (namespaced collections)
    match /staffDemoProfiles/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if false; // seeded/admin-managed for demo
      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "fcmToken",
          "apnsToken",
          "tokenUpdatedAt"
        ]);
      allow delete: if false;
    }

    match /staffDemoSites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isStaffDemoManagerOrAccountant();
    }

    match /staffDemoShifts/{shiftId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isStaffDemoManagerOrAccountant();
    }

    match /staffDemoTimeEntries/{entryId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /staffDemoMessages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isStaffDemoManagerOrAccountant();
    }

    match /staffDemoMessageRecipients/{docId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow create, delete: if isStaffDemoManagerOrAccountant();
    }

    match /staffDemoContent/{contentId} {
      allow read: if isSignedIn() && resource.data.isPublished == true;
      allow write: if isStaffDemoManagerOrAccountant();
    }

    match /staffDemoAvailability/{submissionId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /staffDemoManagerReports/{reportId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /staffDemoEventProofs/{proofId} {
      allow read: if isStaffDemoManagerOrAccountant() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // WalletConnect Auth: one document per user at users/{userId} (linkage + profile)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Chart trending cache: written by server, readable by signed-in users.
    match /chart_trending/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
