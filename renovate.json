{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":separateMultipleMajorReleases"
  ],
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "automerge": false,
  "automergeType": "pr",
  "prConcurrentLimit": 3,
  "prHourlyLimit": 2,
  "timezone": "UTC",
  "schedule": [
    "after 9am and before 5pm on Monday to Friday"
  ],
  "packageRules": [
    {
      "description": "Enable Renovate for pub (Flutter/Dart) dependencies",
      "matchManagers": [
        "pub"
      ],
      "enabled": true
    },
    {
      "description": "Group minor/patch Flutter/Dart updates",
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dart-minor-patch",
      "schedule": [
        "after 9am and before 5pm on Monday to Friday"
      ]
    },
    {
      "description": "Hold genui ^0.7 until genui_google_generative_ai supports newer core (pubspec.yaml)",
      "matchManagers": [
        "pub"
      ],
      "matchPackageNames": [
        "genui"
      ],
      "allowedVersions": "<0.8.0"
    },
    {
      "description": "Hold google_sign_in_mocks ^0.3; 0.4+ needs google_sign_in 7 (firebase_ui on 6)",
      "matchManagers": [
        "pub"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchPackageNames": [
        "google_sign_in_mocks"
      ],
      "allowedVersions": "<0.4.0"
    },
    {
      "description": "Separate major version updates for Flutter SDK",
      "matchPackageNames": [
        "flutter",
        "flutter_test"
      ],
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "flutter-sdk-major",
      "schedule": [
        "after 9am and before 5pm on Monday to Friday"
      ]
    },
    {
      "description": "Separate major version updates for Firebase packages",
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "firebase-major",
      "schedule": [
        "after 9am and before 5pm on Monday to Friday"
      ],
      "matchPackageNames": [
        "/^firebase_/"
      ]
    },
    {
      "description": "Separate major version updates for BLoC packages",
      "matchManagers": [
        "pub"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "bloc-major",
      "schedule": [
        "after 9am and before 5pm on Monday to Friday"
      ],
      "matchPackageNames": [
        "/^flutter_bloc/",
        "/^bloc_test/"
      ]
    },
    {
      "description": "Pin Flutter SDK version",
      "matchPackageNames": [
        "flutter"
      ],
      "matchManagers": [
        "pub"
      ],
      "rangeStrategy": "pin"
    },
    {
      "description": "Ignore dependency_overrides (handled manually)",
      "matchManagers": [
        "pub"
      ],
      "matchDepTypes": [
        "override"
      ],
      "enabled": false
    },
    {
      "description": "Auto-merge patch updates for dev dependencies",
      "matchManagers": [
        "pub"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Hold Dart/analyzer toolchain until coordinated upgrade",
      "matchManagers": [
        "pub"
      ],
      "matchPackageNames": [
        "dart",
        "analysis_server_plugin",
        "analyzer",
        "analyzer_plugin"
      ],
      "enabled": false
    },
    {
      "description": "Hold eslint v10 until eslint-plugin-import supports it",
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "eslint"
      ],
      "allowedVersions": "<10"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": [
      "at any time"
    ],
    "labels": [
      "security",
      "dependencies"
    ]
  }
}
