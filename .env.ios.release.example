# Copy to .env.ios.release (gitignored) for local iOS store/TestFlight lanes.
# Used by ./tool/release_both_stores.sh and manual ./tool/fastlane.sh ios ...

FASTLANE_APP_IDENTIFIER=com.ilkersevim.blocflutter
FASTLANE_APPLE_ID=your-apple-id@example.com
FASTLANE_TEAM_ID=YOUR_TEAM_ID

# Optional: match (https://docs.fastlane.tools/actions/match/)
# Store certificates in a private git repo; set MATCH_READONLY=true on CI.
MATCH_GIT_URL=https://github.com/your-org/ios-certificates.git
MATCH_TYPE=appstore
MATCH_READONLY=true

# Build inputs (defaults match tool/build_ios_with_direnv.sh)
IOS_ENTRYPOINT=lib/main_prod.dart
IOS_BUILD_FLAVOR=
IOS_BUILD_MODE=release
IOS_SKIP_BUILD=false

# Release notes: IOS_RELEASE_NOTES overrides git-derived notes in Fastlane.
IOS_RELEASE_NOTES=
IOS_METADATA_LOCALE=en-US
IOS_SKIP_METADATA=true

# Lane overrides for deploy_all
IOS_DEPLOY_LANE=upload_testflight

# Same compile-time secrets as Android release (via tool/flutter_dart_defines_from_env.sh)
HUGGINGFACE_API_KEY=your_huggingface_api_key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
