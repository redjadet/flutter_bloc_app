{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "test": "npm run build && node --test test/*.test.js",
    "seed:staff-demo": "node tool/seed_staff_demo.js",
    "setup:staff-demo:content": "node tool/setup_staff_demo_content.js",
    "setup:staff-demo": "npm run seed:staff-demo && npm run setup:staff-demo:content",
    "audit:safe": "node ./tool/audit_safe.mjs",
    "deploy": "bash ../tool/firebase_preflight.sh --require-cli && firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24.18.0"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.3.0",
    "googleapis": "^173.0.0",
    "twilio": "^5.13.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^10.2.5"
    },
    "axios": "^1.18.0",
    "protobufjs": "^8.7.1",
    "uuid": "^14.0.1",
    "js-yaml": "^5.2.1",
    "@babel/core": "^8.0.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.5.0",
    "typescript": "^7.0.2"
  },
  "private": true
}
