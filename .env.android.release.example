ANDROID_PACKAGE_NAME=com.ilkersevim.blocflutter
ANDROID_JSON_KEY=/absolute/path/to/google-play-service-account.json
GOOGLE_MAPS_ANDROID_API_KEY=your_android_maps_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
GEMINI_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_MODEL=
HUGGINGFACE_USE_CHAT_COMPLETIONS=

# Optional: FastAPI Cloud chat demo (compile-time --dart-define via
# tool/flutter_dart_defines_from_env.sh when Fastlane builds; see
# docs/integrations/render_fastapi_chat_demo.md).
CHAT_FASTAPICLOUD_DEMO_ENABLED=
CHAT_FASTAPICLOUD_DEMO_BASE_URL=
CHAT_FASTAPICLOUD_DEMO_STRICT=
CHAT_FASTAPICLOUD_DEMO_SECRET=
CHAT_FASTAPICLOUD_HF_READ_TOKEN_CALLABLE=
CHAT_FASTAPICLOUD_HF_READ_TOKEN_CALLABLE_REGION=

# Legacy Render naming for the same demo (still supported by SecretConfig).
CHAT_RENDER_DEMO_ENABLED=
CHAT_RENDER_DEMO_BASE_URL=
CHAT_RENDER_DEMO_STRICT=
CHAT_RENDER_DEMO_SECRET=
CHAT_RENDER_HF_READ_TOKEN_CALLABLE=
CHAT_RENDER_HF_READ_TOKEN_CALLABLE_REGION=

# Optional
ANDROID_PLAY_TRACK=internal
ANDROID_METADATA_LOCALE=en-US
ANDROID_UPLOAD_METADATA=true
ANDROID_UPLOAD_IMAGES=false
ANDROID_UPLOAD_SCREENSHOTS=false
ANDROID_BUILD_FLAVOR=
ANDROID_RELEASE_STATUS=draft
ANDROID_NO_TREE_SHAKE_ICONS=true

# For promotion lane
ANDROID_PROMOTE_FROM=internal
ANDROID_PROMOTE_TO=production
ANDROID_ROLLOUT_FRACTION=0.1
