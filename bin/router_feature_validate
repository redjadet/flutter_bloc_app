#!/usr/bin/env bash
# Run after router or feature extraction changes (auth gates, route builders).
# Usage: ./bin/router_feature_validate

set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck disable=SC1091
source "$WORKSPACE_ROOT/tool/workspace_paths.sh"
cd "$APP_ROOT"

echo "1/3 Formatting..."
dart format lib/app/router/ lib/core/router/ lib/features/auth/ lib/features/settings/ lib/features/iot_demo/

echo "2/3 Analyzing..."
dart analyze lib/app/router/ lib/core/router/ lib/features/

echo "3/3 Running router + feature tests..."
router_feature_stderr="$(mktemp -t router_feature_validate.XXXXXX.stderr)"
trap 'rm -f "$router_feature_stderr"' EXIT

run_router_feature_tests() {
  flutter test \
    test/app/router/ \
    test/features/iot_demo/ \
    test/core/router/app_routes_test.dart \
    test/core/di/register_auth_services_test.dart \
    test/core/di/injector_helpers_test.dart \
    test/sign_in_page_test.dart
}

rm -rf build/unit_test_assets

if ! run_router_feature_tests 2> >(tee "$router_feature_stderr" >&2); then
  if grep -Eq "build/unit_test_assets|NativeAssetsManifest\\.json|build/native_assets/macos/native_assets\\.json" "$router_feature_stderr"; then
    echo "router_feature_validate: flutter unit_test_assets/native-assets failed; cleaning build assets and retrying once"
    rm -rf build/unit_test_assets build/native_assets
    run_router_feature_tests
  else
    exit 1
  fi
fi

echo "Router/feature validation passed."
