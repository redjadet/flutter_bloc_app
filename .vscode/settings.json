{
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "Dart-Code.dart-code",
  "dart.lineLength": 100,
  "dart.completeFunctionCalls": true,
  "dart.updateImportsOnRename": true,
  "dart.showTodos": true,
  "dart.warnWhenEditingFilesOutsideWorkspace": true,
  "dart.runPubGetOnPubspecChanges": "prompt",
  "dart.previewFlutterUiGuides": true,
  "dart.flutterShowStructuredErrors": true,
  "dart.flutterCreateOrganization": "com.example",
  "dart.flutterOpenDevTools": "flutter",
  "editor.rulers": [
    100
  ],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/.dart_tool": true,
    "**/.idea": true,
    "**/.fleet": true,
    "**/.fvm": true,
    "**/build": true,
    "**/ios/Pods": true,
    "**/android/.gradle": true,
    "**/android/local.properties": true,
    "**/.vscode": false
  },
  "search.exclude": {
    "**/build": true,
    "**/.dart_tool": true,
    "**/ios/Pods": true,
    "**/android/.gradle": true,
    "**/.git": true
  },
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.showGutterCoverage": true,
  "coverage-gutters.highlightCovered": true,
  "coverage-gutters.coverageFileNames": [
    "lcov.info",
    "coverage/lcov.info"
  ],
  "cSpell.enabled": true,
  "cSpell.allowedFileTypes": [
    "dart"
  ],
  "cSpell.ignorePaths": [
    "**/AGENTS.md",
    "**/*.g.dart",
    "**/*.freezed.dart",
    "**/*.gen.dart",
    "**/*.mocks.dart",
    "apps/mobile/lib/l10n/app_localizations*.dart",
    "**/build/**",
    "analysis_options.yaml",
    ".vscode/settings.json",
    ".vscode/extensions.json",
    "test/**/*.dart",
    "**/*.arb",
    "**/*.yaml",
    "**/*.xml",
    "**/*.yml",
    "**/*.json",
    "**/*.lock",
    "**/*.md",
    "**/*.plist",
    "tool/**",
    "third_party/**",
    "**/.pub-cache/**",
    "../../../flutter/**"
  ],
  "cSpell.checkPaths": [
    "apps/mobile/lib/**",
    "apps/mobile/test/**",
    "!README.md",
    "!analysis_options.yaml",
    "!pubspec.yaml",
    "!.vscode/*.json",
    "!AGENTS.md",
    "!apps/mobile/lib/**/*.g.dart",
    "!apps/mobile/lib/**/*.freezed.dart",
    "!apps/mobile/lib/**/*.gen.dart",
    "!apps/mobile/lib/**/*.mocks.dart",
    "!apps/mobile/lib/l10n/app_localizations*.dart"
  ],
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.rulers": [
      100
    ],
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "editor.inlayHints.enabled": "on"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "cSpell.words": [
    "apikey",
    "appbundle",
    "applinks",
    "appspot",
    "behaviour",
    "Comfortaa",
    "deeplink",
    "firepit",
    "flutterbloc",
    "flutterfire",
    "gmaps",
    "goldens",
    "huggingface",
    "igaming",
    "loggedout",
    "nonbuilder",
    "playlearn",
    "preferences",
    "prefs",
    "pubspec",
    "Roboto",
    "Skeletonized",
    "snackbars",
    "sqflite",
    "standardise",
    "Streamable",
    "Syncable",
    "syncables",
    "Türkçe",
    "Uncomplete",
    "walletconnect",
    "webp",
    "xsmall"
  ],
  "files.associations": {
    "*.config": "plaintext"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "typescript.tsserver.exclude": [
    "supabase/functions/**"
  ],
  "javascript.tsserver.exclude": [
    "supabase/functions/**"
  ],
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.files.exclude": {
    "**/windows/flutter/**": true,
    "**/linux/flutter/**": true
  },
  "cmake.sourceDirectory": "${workspaceFolder}/apps/other_platforms/windows/runner",
  "dart.analysisExcludedFolders": [
    "${workspaceFolder}/backend",
    "${workspaceFolder}/demos",
    "${workspaceFolder}/third_party",
    "${workspaceFolder}/.worktrees"
  ]
}
